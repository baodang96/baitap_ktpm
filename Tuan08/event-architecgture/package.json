{
  "name": "movie-ticket-system",
  "version": "1.0.0",
  "description": "Event-Driven Movie Ticket System",
  "scripts": {
    "start:gateway": "npm start --prefix api-gateway",
    "start:user": "npm start --prefix user-service",
    "start:movie": "npm start --prefix movie-service",
    "start:booking": "npm start --prefix booking-service",
    "start:payment": "npm start --prefix payment-service",
    "start:notification": "npm start --prefix notification-service",
    "start:frontend": "npm run dev --prefix frontend",
    "install:all": "npm install --prefix api-gateway && npm install --prefix user-service && npm install --prefix movie-service && npm install --prefix booking-service && npm install --prefix payment-service && npm install --prefix notification-service && npm install --prefix frontend",
    "start:all": "npx concurrently \"npm:start:gateway\" \"npm:start:user\" \"npm:start:movie\" \"npm:start:booking\" \"npm:start:payment\" \"npm:start:notification\" \"npm:start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
